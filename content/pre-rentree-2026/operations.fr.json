      "fields": [
        { "id": "operationalCommunications", "label": "Communications opérationnelles", "type": "RADIO", "required": true },
        { "id": "newsletterConsent", "label": "Newsletter facultative", "type": "RADIO", "required": false },
        { "id": "imageConsent", "label": "Droit à l’image facultatif", "type": "RADIO", "required": false },
        { "id": "pedagogicalRecordingConsent", "label": "Enregistrement pédagogique facultatif", "type": "RADIO", "required": false }
      ]
    },
    {
      "id": "urgence",
      "title": "Fiche d’urgence strictement nécessaire",
      "purpose": "Recueillir après confirmation les coordonnées indispensables à la sécurité.",
      "privacyGate": true,
      "fields": [
        { "id": "emergencyContact", "label": "Contact d’urgence", "type": "TEXT", "required": true },
        { "id": "emergencyPhone", "label": "Téléphone d’urgence", "type": "PHONE", "required": true },
        { "id": "authorizedPickup", "label": "Personne autorisée à récupérer l’élève", "type": "TEXT", "required": false },
        { "id": "relationship", "label": "Lien avec l’élève", "type": "TEXT", "required": false },
        { "id": "strictNeeds", "label": "Besoins spécifiques strictement nécessaires", "type": "LONG_TEXT", "required": false }
      ]
    }
  ],

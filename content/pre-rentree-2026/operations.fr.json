      "purpose": "Transmettre les informations nécessaires à la présence au stage.",
      "privacyGate": true,
      "fields": [
        { "id": "reservationId", "label": "Identifiant de réservation", "type": "IDENTIFIER", "required": true },
        { "id": "datesAndTimes", "label": "Dates et horaires", "type": "LONG_TEXT", "required": true },
        { "id": "room", "label": "Salle confirmée", "type": "TEXT", "required": true },
        { "id": "material", "label": "Matériel à apporter", "type": "LONG_TEXT", "required": true }
      ]
    },
    {
      "id": "consentements-confidentialite",
      "title": "Consentements et notice de confidentialité",
      "purpose": "Séparer les usages nécessaires des choix facultatifs, après validation confidentialité.",

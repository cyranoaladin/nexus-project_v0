{
  "schemaVersion": "1.0.0",
  "version": "1.0.0",
  "locale": "fr-TN",
  "reviewForms": [
    {
      "id": "demande-information",
      "title": "Formulaire de demande d’information",
      "purpose": "Recueillir uniquement les éléments nécessaires au premier contact.",
      "privacyGate": true,
      "fields": [
        { "id": "requestId", "label": "Identifiant de demande", "type": "IDENTIFIER", "required": true },
        { "id": "entryLevel", "label": "Classe de rentrée", "type": "SELECT", "required": true },
        { "id": "subjects", "label": "Matières envisagées", "type": "CHECKBOX", "required": true },
        { "id": "contactChannel", "label": "Canal de réponse souhaité", "type": "SELECT", "required": true }
      ]
    },
    {
      "id": "qualification-pedagogique",
      "title": "Fiche de qualification pédagogique",
      "purpose": "Vérifier le niveau, le profil et la compatibilité du parcours sans diagnostic médical.",
      "privacyGate": true,
      "fields": [
        { "id": "requestId", "label": "Identifiant de demande", "type": "IDENTIFIER", "required": true },
        { "id": "academicProfile", "label": "Profil pédagogique déclaré", "type": "LONG_TEXT", "required": true },
        { "id": "needs", "label": "Besoins scolaires strictement nécessaires", "type": "LONG_TEXT", "required": false },
        { "id": "validatorRole", "label": "Rôle du validateur Nexus", "type": "TEXT", "required": true }
      ]
    },
    {
      "id": "proposition-parcours",
      "title": "Proposition de parcours",
      "purpose": "Formaliser le parcours proposé et sa durée de maintien.",
      "privacyGate": true,
      "fields": [
        { "id": "proposalId", "label": "Identifiant de proposition", "type": "IDENTIFIER", "required": true },
        { "id": "moduleIds", "label": "Modules proposés", "type": "CHECKBOX", "required": true },
        { "id": "schedule", "label": "Créneaux proposés", "type": "LONG_TEXT", "required": true },
        { "id": "expiresAt", "label": "Expiration de la proposition", "type": "DATETIME", "required": true }
      ]
    },
    {
      "id": "recapitulatif-tarifaire",
      "title": "Récapitulatif tarifaire",
      "purpose": "Présenter le prix, l’acompte exact et le solde du parcours validé.",
      "privacyGate": true,
      "fields": [
        { "id": "proposalId", "label": "Identifiant de proposition", "type": "IDENTIFIER", "required": true },
        { "id": "totalPrice", "label": "Prix total", "type": "AMOUNT", "required": true },
        { "id": "deposit", "label": "Acompte de 30 %", "type": "AMOUNT", "required": true },
        { "id": "balance", "label": "Solde", "type": "AMOUNT", "required": true }
      ]
    },
    {
      "id": "demande-acompte",
      "title": "Demande d’acompte",
      "purpose": "Demander l’acompte après validation du parcours et transmission des conditions.",
      "privacyGate": true,
      "fields": [
        { "id": "proposalId", "label": "Identifiant de proposition", "type": "IDENTIFIER", "required": true },
        { "id": "deposit", "label": "Montant de l’acompte", "type": "AMOUNT", "required": true },
        { "id": "paymentDeadline", "label": "Échéance de l’acompte", "type": "DATETIME", "required": true },
        { "id": "termsReference", "label": "Référence des conditions transmises", "type": "IDENTIFIER", "required": true }
      ]
    },
    {
      "id": "recu-acompte",
      "title": "Reçu d’acompte",
      "purpose": "Tracer l’encaissement sans stocker de donnée bancaire.",
      "privacyGate": true,
      "fields": [
        { "id": "receiptId", "label": "Numéro de reçu", "type": "IDENTIFIER", "required": true },
        { "id": "amountReceived", "label": "Montant reçu", "type": "AMOUNT", "required": true },
        { "id": "receivedAt", "label": "Date de réception", "type": "DATETIME", "required": true },
        { "id": "paymentReference", "label": "Référence de paiement", "type": "IDENTIFIER", "required": true }
      ]
    },
    {
      "id": "confirmation-reservation",
      "title": "Confirmation de réservation",
      "purpose": "Confirmer la place après réception de l’acompte.",

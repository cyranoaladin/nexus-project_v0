{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://nexusreussite.academy/schemas/pre-rentree-2026-parent-guide.schema.json",
  "type":"object",
  "additionalProperties":false,
  "required":["schemaVersion","contentVersion","locale","status","documentPackageVersion","documentEditionDate","snapshotBuiltAt","sections"],
  "properties":{
    "schemaVersion":{"const":"1.0.0"},
    "contentVersion":{"type":"string","minLength":1},
    "locale":{"const":"fr-TN"},
    "status":{"const":"DRAFT_FOR_OWNER_REVIEW"},
    "documentPackageVersion":{"type":"string","pattern":"^[0-9]+\\.[0-9]+\\.[0-9]+-rc\\.[0-9]+$"},
    "documentEditionDate":{"type":"string","format":"date"},
    "snapshotBuiltAt":{"type":"string","format":"date-time"},
    "sections":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/section"}}
  },
  "$defs":{
    "evidenceRef":{"type":"string","pattern":"^/"},
    "textBlock":{"type":"object","additionalProperties":false,"required":["id","kind","text","evidenceRefs"],"properties":{"id":{"type":"string"},"kind":{"const":"EVIDENCED_TEXT"},"text":{"type":"string","minLength":1},"evidenceRefs":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/evidenceRef"}}}},
    "procedureBlock":{"type":"object","additionalProperties":false,"required":["id","kind","steps"],"properties":{"id":{"type":"string"},"kind":{"const":"EVIDENCED_PROCEDURE"},"steps":{"type":"array","minItems":1,"items":{"type":"object","additionalProperties":false,"required":["text","evidenceRefs"],"properties":{"text":{"type":"string","minLength":1},"evidenceRefs":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/evidenceRef"}}}}}}},
    "dynamicBlock":{"type":"object","additionalProperties":false,"required":["id","kind","sourceRef"],"properties":{"id":{"type":"string"},"kind":{"const":"DYNAMIC_REFERENCE"},"sourceRef":{"$ref":"#/$defs/evidenceRef"}}},
    "block":{"oneOf":[{"$ref":"#/$defs/textBlock"},{"$ref":"#/$defs/procedureBlock"},{"$ref":"#/$defs/dynamicBlock"}]},
    "section":{"type":"object","additionalProperties":false,"required":["id","title","blocks"],"properties":{"id":{"type":"string"},"title":{"type":"string","minLength":1},"blocks":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/block"}}}}
  }
}

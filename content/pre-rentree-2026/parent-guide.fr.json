  "sections": [
    {
      "id": "essentiel",
      "title": "L’essentiel",
      "blocks": [
        {
          "id": "dates-lieu",
          "kind": "EVIDENCED_TEXT",
          "text": "Les stages se déroulent du 17 au 28 août 2026 à Mutuelleville, Tunis, avec une pause les 22 et 23 août.",
          "evidenceRefs": [
            "/campaign/startDate",
            "/campaign/endDate",
            "/campaign/noClassDates",
            "/campaign/venue",
            "/ownerDecisions/calendar"
          ]
        },
        {
          "id": "quatre-niveaux",
          "kind": "EVIDENCED_TEXT",
          "text": "Les parcours concernent les élèves entrant en 3e, Seconde, Première ou Terminale à la rentrée 2026-2027.",
          "evidenceRefs": [
            "/levels"
          ]
        },
        {
          "id": "format-matiere",
          "kind": "EVIDENCED_TEXT",
          "text": "Chaque matière comprend cinq séances de deux heures, soit dix heures de travail structurées.",
          "evidenceRefs": [
            "/modules",
            "/packs/0/sessionsPerSubject",
            "/packs/0/sessionDurationHours",
            "/packs/0/hoursPerSubject"
          ]
        },
        {
          "id": "groupes",
          "kind": "DYNAMIC_REFERENCE",
          "sourceRef": "/campaign/capacityByOffer"
        },
        {
          "id": "plages-horaires",
          "kind": "EVIDENCED_TEXT",
          "text": "Les plages publiées sont 08:30-10:30, 10:45-12:45, 13:30-15:30 et 15:45-17:45. L’affectation précise d’un groupe à une plage est communiquée après confirmation.",
          "evidenceRefs": [
            "/campaign/blocks",
            "/ownerDecisions/calendar/publishedDailyTimeSlots"
          ]
        }
      ]
    },
    {
      "id": "offres",
      "title": "Fondations ou Premium ?",
      "blocks": [
        {
          "id": "fondations-positionnement",
          "kind": "EVIDENCED_TEXT",
          "text": "Nexus Fondations accompagne l’entrée en 3e et en Seconde dans un groupe de quatre à six élèves.",
          "evidenceRefs": [
            "/offers/levels",
            "/campaign/capacityByOffer/FONDATIONS"
          ]
        },
        {
          "id": "premium-positionnement",
          "kind": "EVIDENCED_TEXT",
          "text": "Nexus Premium concerne l’entrée en Première et en Terminale, dans un groupe de trois à cinq élèves.",
          "evidenceRefs": [
            "/offers/levels",
            "/campaign/capacityByOffer/PREMIUM"
          ]
        },
        {
          "id": "seconde-sans-snt",
          "kind": "EVIDENCED_TEXT",
          "text": "Pour l’entrée en Seconde, les matières proposées en 2026 sont Mathématiques, Physique-Chimie et Français. La SNT et l’initiation informatique sont exclues de cette campagne.",
          "evidenceRefs": [
            "/ownerDecisions/secondeSubjects",
            "/offers/levels/1/subjects"
          ]
        },
        {
          "id": "capacites-gatees",
          "kind": "EVIDENCED_TEXT",
          "text": "Le parcours précis est communiqué après étude du niveau, des matières demandées, du profil et de la cohérence du groupe.",
          "evidenceRefs": [
            "/offers/levels",
            "/content/practical/preRegistrationNotice"
          ]
        }
      ]
    },
    {
      "id": "pourquoi",
      "title": "Pourquoi une pré-rentrée ?",
      "blocks": [
        {
          "id": "reprendre",
          "kind": "EVIDENCED_TEXT",
          "text": "Réactiver les acquis utiles et repérer les priorités avant les premiers chapitres de l’année.",
          "evidenceRefs": [
            "/modules"
          ]
        },
        {
          "id": "methodes",
          "kind": "EVIDENCED_TEXT",
          "text": "Travailler les méthodes attendues dans la classe de rentrée, sans garantie de résultat ni promesse de progression chiffrée.",
          "evidenceRefs": [
            "/modules",
            "/commercialContract"
          ]
        },
        {
          "id": "transition",
          "kind": "EVIDENCED_TEXT",
          "text": "Préparer la transition vers le brevet, le lycée, les spécialités, l’EAF, le baccalauréat ou la Philosophie selon le niveau.",
          "evidenceRefs": [
            "/modules"
          ]
        }
      ]
    },
    {
      "id": "fonctionnement",
      "title": "Comment se déroule le travail ?",
      "blocks": [
        {
          "id": "socle-prouve",
          "kind": "EVIDENCED_TEXT",
          "text": "Chaque séance s’appuie sur des objectifs annoncés, un entraînement guidé, une correction explicitée, des consignes préparées et un travail orienté vers les priorités observées.",
          "evidenceRefs": [
            "/commercialContract",
            "/ownerDecisions/pedagogicalServices/components/0"
          ]
        },
        {
          "id": "positionnement-cible",
          "kind": "EVIDENCED_TEXT",
          "text": "Le positionnement initial fait partie du parcours cible approuvé. Il ne sera annoncé comme prestation garantie qu’après validation des outils, des procédures, de la traçabilité et de la confidentialité.",
          "evidenceRefs": [
            "/capabilities",
            "/ownerDecisions/pedagogicalServices/components/1"
          ]
        },
        {
          "id": "bilan-cible",
          "kind": "EVIDENCED_TEXT",
          "text": "Le bilan parents et le plan d’action font partie du parcours cible approuvé. Leur inclusion publique reste bloquée jusqu’à validation complète de la chaîne Parcours 360, de la relecture humaine, du stockage sécurisé et de la capacité de production.",
          "evidenceRefs": [
            "/capabilities",
            "/ownerDecisions/pedagogicalServices/components/2"
          ]
        }
      ]
    },
    {
      "id": "parcours-fondations",
      "title": "Le parcours Fondations",
      "blocks": [
        {
          "id": "fondations-services",
          "kind": "DYNAMIC_REFERENCE",
          "sourceRef": "/offers/levels/0/serviceCapabilityIds"
        },
        {
          "id": "fondations-cadre",
          "kind": "EVIDENCED_TEXT",
          "text": "Fondations est proposé à la matière, sans remise multimatières. Le groupe ouvre à partir de quatre inscriptions confirmées et accueille au maximum six élèves.",
          "evidenceRefs": [
            "/offers/levels/0/pricing",
            "/offers/levels/1/pricing",
            "/campaign/capacityByOffer/FONDATIONS"
          ]
        }
      ]
    },
    {
      "id": "parcours-premium",
      "title": "Le parcours Premium",
      "blocks": [
        {
          "id": "premium-services",
          "kind": "DYNAMIC_REFERENCE",
          "sourceRef": "/offers/levels/2/serviceCapabilityIds"
        },
        {
          "id": "premium-cadre",
          "kind": "EVIDENCED_TEXT",
          "text": "Premium est proposé en packs d’une à quatre matières. Le groupe ouvre à partir de trois inscriptions confirmées et accueille au maximum cinq élèves.",
          "evidenceRefs": [
            "/offers/levels/2/pricing",
            "/campaign/capacityByOffer/PREMIUM"
          ]
        },
        {
          "id": "premium-gate",
          "kind": "EVIDENCED_TEXT",
          "text": "Les fonctions de diagnostic, de bilan et de plan d’action ne sont publiées comme incluses qu’après validation opérationnelle de leurs gates.",
          "evidenceRefs": [
            "/capabilities",
            "/ownerDecisions/pedagogicalServices"
          ]
        }
      ]
    },
    {
      "id": "catalogue",
      "title": "Choisir son parcours par niveau",
      "blocks": [
        {
          "id": "catalogue-offres",
          "kind": "DYNAMIC_REFERENCE",
          "sourceRef": "/offers/levels"
        },
        {
          "id": "catalogue-programmes",
          "kind": "DYNAMIC_REFERENCE",
          "sourceRef": "/modules"
        },
        {
          "id": "adaptation",
          "kind": "EVIDENCED_TEXT",
          "text": "Le niveau des exercices est ajusté au profil déclaré et à la composition pédagogique du groupe. Les programmes détaillés restent soumis à validation humaine matière par matière.",
          "evidenceRefs": [
            "/modules",
            "/campaign/operationalGates"
          ]
        }
      ]
    },
    {
      "id": "planning",
      "title": "Calendrier et plages horaires",
      "blocks": [
        {
          "id": "periode",
          "kind": "EVIDENCED_TEXT",
          "text": "Période : du lundi 17 au vendredi 28 août 2026. Pause : samedi 22 et dimanche 23 août.",
          "evidenceRefs": [
            "/campaign/startDate",
            "/campaign/endDate",
            "/campaign/noClassDates",
            "/ownerDecisions/calendar"
          ]
        },
        {
          "id": "blocs",
          "kind": "EVIDENCED_TEXT",
          "text": "Plages quotidiennes : 08:30-10:30 ; 10:45-12:45 ; 13:30-15:30 ; 15:45-17:45.",
          "evidenceRefs": [
            "/campaign/blocks",
            "/ownerDecisions/calendar/publishedDailyTimeSlots"
          ]
        },
        {
          "id": "affectations-gate",
          "kind": "EVIDENCED_TEXT",
          "text": "Les affectations précises par niveau, matière, enseignant et salle ne sont pas publiées avant validation opérationnelle. Elles sont communiquées avec la confirmation du groupe.",
          "evidenceRefs": [
            "/campaign/operationalGates",
            "/ownerDecisions/calendar/groupSubjectRoomAssignments"
          ]
        }
      ]
    },
    {
      "id": "tarifs",
      "title": "Tarifs des stages de pré-rentrée 2026",
      "blocks": [
        {
          "id": "tarifs-offres",
          "kind": "DYNAMIC_REFERENCE",
          "sourceRef": "/offers"
        },
        {
          "id": "tarifs-premium",
          "kind": "DYNAMIC_REFERENCE",
          "sourceRef": "/packs"
        },
        {
          "id": "acompte-exact",
          "kind": "EVIDENCED_TEXT",
          "text": "L’acompte correspond exactement à 30 % du total validé ; le solde complète le prix sans erreur d’arrondi.",
          "evidenceRefs": [
            "/offers/depositRate",
            "/packs"
          ]
        },
        {
          "id": "justification",
          "kind": "EVIDENCED_TEXT",
          "text": "Le tarif rémunère dix heures par matière, un groupe réduit, des séances préparées, un entraînement guidé et une correction explicitée. Aucun résultat scolaire n’est garanti.",
          "evidenceRefs": [
            "/pricing",
            "/commercialContract",
            "/campaign/capacityByOffer"
          ]
        }
      ]
    },
    {
      "id": "equipe",
      "title": "Cadre de qualité pédagogique",
      "blocks": [
        {
          "id": "qualite-prouvable",
          "kind": "EVIDENCED_TEXT",
          "text": "La qualité annoncée repose sur la préparation des cinq séances, des objectifs explicites, des exercices structurés et une correction méthodique.",
          "evidenceRefs": [
            "/modules",
            "/commercialContract"
          ]
        },
        {
          "id": "affectations",
          "kind": "EVIDENCED_TEXT",
          "text": "Les affectations nominatives, les qualifications et les disponibilités des enseignants ne sont communiquées qu’après vérification documentaire et validation du groupe.",
          "evidenceRefs": [
            "/staffingMatrix",
            "/campaign/operationalGates"
          ]
        }
      ]
    },
    {
      "id": "reservation",
      "title": "De la demande d’information à la réservation",
      "blocks": [
        {
          "id": "reservation-etapes",
          "kind": "EVIDENCED_PROCEDURE",
          "steps": [
            {
              "text": "La famille demande le programme ou un conseil, sans paiement ni réservation.",
              "evidenceRefs": [
                "/content/practical/preRegistrationNotice"
              ]
            },
            {
              "text": "Nexus qualifie le niveau, les matières, le profil, le planning et la cohérence du groupe.",
              "evidenceRefs": [
                "/academicProfiles",
                "/campaign/operationalGates"
              ]
            },
            {
              "text": "Nexus transmet une proposition de parcours avec prix, acompte, solde et conditions applicables.",
              "evidenceRefs": [
                "/offers",
                "/packs",
                "/legal"
              ]
            },
            {
              "text": "Après validation du parcours et réception de l’acompte exact, l’inscription est confirmée et la place réservée.",
              "evidenceRefs": [
                "/content/practical/noOnlinePaymentNotice",
                "/offers/depositRate"
              ]
            }
          ]
        },
        {
          "id": "conditions-manquantes",
          "kind": "EVIDENCED_TEXT",
          "text": "Les règles d’annulation, d’absence, de report, de remboursement et l’échéance contractuelle du solde restent exclues tant qu’une version juridique approuvée manque.",
          "evidenceRefs": [
            "/legal"
          ]
        }
      ]
    },
    {
      "id": "pratique",
      "title": "Informations pratiques",
      "blocks": [
        {
          "id": "materiel",
          "kind": "DYNAMIC_REFERENCE",
          "sourceRef": "/content/practical/materialsBySubject"
        },
        {
          "id": "physique",
          "kind": "EVIDENCED_TEXT",
          "text": "Les séances de Physique-Chimie sont théoriques et méthodologiques ; aucune activité de laboratoire n’est annoncée.",
          "evidenceRefs": [
            "/content/practical/materialsBySubject/PHYSIQUE_CHIMIE"
          ]
        },
        {
          "id": "presentiel",
          "kind": "EVIDENCED_TEXT",
          "text": "La campagne 2026 est organisée en présentiel à Mutuelleville. Aucun replay, plateforme, dashboard ou accompagnement annuel n’est inclus dans l’offre publiée.",

  "sections": [
    {
      "id": "essentiel",
      "title": "L’essentiel en une page",
      "blocks": [
        {
          "id": "une-matiere-une-semaine",
          "kind": "EVIDENCED_TEXT",
          "text": "Chaque matière comprend cinq séances de deux heures organisées sur une semaine ; la campagne complète se déroule sur deux semaines.",
          "evidenceRefs": ["/packs/0/sessionsPerSubject", "/packs/0/sessionDurationHours", "/packs/0/hoursPerSubject", "/schedule/weeks"]
        }
      ]
    },
    {
      "id": "pourquoi",
      "title": "Pourquoi une pré-rentrée ?",
      "blocks": [
        {
          "id": "reprise-progressive",
          "kind": "EVIDENCED_TEXT",
          "text": "Reprendre progressivement les acquis après la coupure estivale.",
          "evidenceRefs": ["/modules"]
        },
        {
          "id": "consolider-automatismes",
          "kind": "EVIDENCED_TEXT",
          "text": "Consolider les automatismes utiles avant les premiers chapitres de la rentrée.",
          "evidenceRefs": ["/modules"]
        },
        {
          "id": "methodes-niveau",
          "kind": "EVIDENCED_TEXT",
          "text": "Découvrir ou reprendre les méthodes attendues dans la classe d’entrée.",
          "evidenceRefs": ["/levels", "/modules"]
        },
        {
          "id": "identifier-priorites",
          "kind": "EVIDENCED_TEXT",
          "text": "Identifier les priorités de travail grâce au positionnement et aux évaluations rapides.",
          "evidenceRefs": ["/content/method/0", "/modules"]
        },
        {
          "id": "preparer-transition",
          "kind": "EVIDENCED_TEXT",
          "text": "Préparer la transition vers le lycée ou la classe supérieure avec des repères concrets.",
          "evidenceRefs": ["/levels", "/modules"]
        }
      ]
    },
    {
      "id": "fonctionnement",
      "title": "Comment fonctionne l’accompagnement ?",
      "blocks": [
        {
          "id": "methode-pedagogique",
          "kind": "EVIDENCED_TEXT",
          "text": "Le travail associe positionnement initial, objectifs explicites, accompagnement guidé, exercices progressifs, corrections, évaluations rapides, supports, livrables, synthèse et recommandations.",
          "evidenceRefs": ["/content/method", "/modules"],
          "capabilityId": "positionnement-initial"
        }
      ]
    },
    {
      "id": "parcours",
      "title": "Choisir le parcours de son enfant",
      "blocks": [
        { "id": "niveaux-et-matieres", "kind": "DYNAMIC_REFERENCE", "sourceRef": "/levels" }
      ]
    },
    {
      "id": "planning",
      "title": "Planning des deux semaines",
      "blocks": [
        {
          "id": "repartition-semaines",
          "kind": "EVIDENCED_TEXT",
          "text": "Mathématiques et Français sont programmés pendant la première semaine ; informatique, NSI ou SNT et Physique-Chimie pendant la seconde. La présence dépend des matières choisies.",
          "evidenceRefs": ["/schedule/weeks", "/subjects"]
        }
      ]
    },
    {
      "id": "tarifs",
      "title": "Tarifs des stages de pré-rentrée 2026",
      "blocks": [
        { "id": "formules-tarifaires", "kind": "DYNAMIC_REFERENCE", "sourceRef": "/packs" }
      ]
    },
    {
      "id": "pre-inscription",
      "title": "Pré-inscription et confirmation",
      "blocks": [
        {
          "id": "procedure-confirmation",
          "kind": "EVIDENCED_PROCEDURE",
          "steps": [
            { "text": "La famille transmet une demande de pré-inscription sans paiement.", "evidenceRefs": ["/content/practical/preRegistrationNotice"] },
            { "text": "Nexus étudie le niveau, les matières et le profil pédagogique déclaré.", "evidenceRefs": ["/academicProfiles", "/content/practical/groupCompositionNotice"] },
            { "text": "Nexus vérifie les effectifs et la cohérence pédagogique du groupe.", "evidenceRefs": ["/campaign/capacity", "/content/practical/groupCompositionNotice"] },
            { "text": "La décision d’ouverture et la proposition de parcours sont communiquées.", "evidenceRefs": ["/campaign/decisionDeadline", "/content/practical/groupCompositionNotice"] },
            { "text": "Les conditions applicables sont transmises avant toute confirmation.", "evidenceRefs": ["/content/practical/noOnlinePaymentNotice", "/legal"] },
            { "text": "La famille confirme ensuite l’inscription selon la proposition validée.", "evidenceRefs": ["/content/practical/preRegistrationNotice"] },
            { "text": "L’acompte correspondant au pack validé est alors demandé.", "evidenceRefs": ["/packs", "/content/faq"] },
            { "text": "Le solde est réglé selon les conditions contractuelles communiquées.", "evidenceRefs": ["/packs", "/legal"] }
          ]
        }
      ]
    },

FROM node:22.23.1-alpine@sha256:16e22a550f3863206a3f701448c45f7912c6896a62de43add43bb9c86130c3e2

WORKDIR /app

COPY package.json package-lock.json .npmrc ./
COPY scripts/validate-npm-tree.js ./scripts/validate-npm-tree.js
COPY security/npm-tree-exceptions.json ./security/npm-tree-exceptions.json

RUN test "$(node --version)" = "v22.23.1"
RUN test "$(npm --version)" = "10.9.8"
RUN npm ci
RUN npm ls --all --json --long > /tmp/npm-tree.json 2> /tmp/npm-tree.stderr; \
    ls_code=$?; \
    echo "NPM_LS_EXIT_CODE=$ls_code"; \
    node scripts/validate-npm-tree.js \
      --tree /tmp/npm-tree.json \
      --exceptions security/npm-tree-exceptions.json
RUN npm audit --omit=dev --audit-level=high
RUN node - <<'NODE'
const fs = require('node:fs');
const path = require('node:path');

for (const packageName of [
  '@prisma/client',
  '@cortex-js/compute-engine',
  'pdfjs-dist',
  'sharp',
]) {
  const packageJson = JSON.parse(
    fs.readFileSync(path.join('node_modules', packageName, 'package.json'), 'utf8'),
  );
  console.log(packageName, packageJson.version);
}

for (const scope of ['@emnapi', '@napi-rs', '@img']) {
  const directory = `node_modules/${scope}`;
  console.log(scope, fs.existsSync(directory) ? fs.readdirSync(directory).sort() : []);
}
NODE

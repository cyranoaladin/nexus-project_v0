{
  "name": "nexus-reussite-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "pre-rentree:clean": "python scripts/pre-rentree/clean_artifacts.py .artifacts/pre-rentree-2026",
    "pre-rentree:snapshot": "tsx scripts/pre-rentree/generate-publication-json-schema.ts --output scripts/pre-rentree/schemas/publication-snapshot.schema.json && tsx scripts/pre-rentree/build-publication-snapshot.ts --repo-root . --source-repo-sha a1192c8dccf8eaa6ae223265a3bc9ceb56a6fff0 --output generated/pre-rentree-2026/publication.snapshot.json",
    "pre-rentree:commercial-contract": "tsx --conditions=react-server scripts/pre-rentree/build-commercial-contract.ts --output .artifacts/pre-rentree-2026/commercial-contract.snapshot.json",
    "pre-rentree:week-one": "npm run pre-rentree:commercial-contract && python scripts/pre-rentree/render_week_one_kit.py --content content/pre-rentree-2026/week-one-campaign.fr.json --commercial .artifacts/pre-rentree-2026/commercial-contract.snapshot.json --output assets/campaigns/pre-rentree-2026/week-one",
    "pre-rentree:parent-documents": "npm run pre-rentree:commercial-contract && python scripts/pre-rentree/render_parent_document_kit.py --content content/pre-rentree-2026/parent-documents.fr.json --commercial .artifacts/pre-rentree-2026/commercial-contract.snapshot.json --output assets/campaigns/pre-rentree-2026/parent-documents",
    "pre-rentree:full-campaign": "npm run pre-rentree:commercial-contract && python scripts/pre-rentree/render_full_campaign.py --content content/pre-rentree-2026/full-campaign.fr.json --commercial .artifacts/pre-rentree-2026/commercial-contract.snapshot.json --output assets/campaigns/pre-rentree-2026/full-campaign",
    "pre-rentree:priority-resources": "python scripts/pre-rentree/render_priority_resource_kit.py --content content/pre-rentree-2026/priority-resources.fr.json --matrix content/pre-rentree-2026/official-programme-matrix.fr.json --output assets/pedagogy/pre-rentree-2026/priority-resources",
    "pre-rentree:economic-simulation": "npm run pre-rentree:commercial-contract && python scripts/pre-rentree/render_economic_simulation.py --commercial .artifacts/pre-rentree-2026/commercial-contract.snapshot.json --operations content/pre-rentree-2026/operations.fr.json --output assets/operations/pre-rentree-2026/economic-simulation",
    "pre-rentree:release-inventory": "python scripts/pre-rentree/build_release_inventory.py --repo-root . --output assets/campaigns/pre-rentree-2026/release-inventory.json",
    "pre-rentree:public-qa-manifest": "node scripts/pre-rentree/build_public_qa_manifest.mjs",
    "pre-rentree:test:ts": "jest --config jest.unit.config.js --runInBand --testPathPattern='pre-rentree-2026'",
    "pre-rentree:test:py": "python -m pytest scripts/pre-rentree/tests -q",
    "pre-rentree:build": "python scripts/pre-rentree/generate_documents.py --snapshot generated/pre-rentree-2026/publication.snapshot.json --output .artifacts/pre-rentree-2026/build",
    "pre-rentree:audit": "python scripts/pre-rentree/verify_reproducibility.py --snapshot generated/pre-rentree-2026/publication.snapshot.json --reference .artifacts/pre-rentree-2026/build --output-report .artifacts/pre-rentree-2026/build/REVIEW/AUDIT/reproducibility-report.json && python scripts/pre-rentree/verify_release.py --artifact-root .artifacts/pre-rentree-2026/build --repo-root . --write-governance",
    "pre-rentree:package": "python scripts/pre-rentree/package_documents.py --artifact-root .artifacts/pre-rentree-2026/build --output .artifacts/pre-rentree-2026/packages --repo-root .",
    "pre-rentree:verify": "python scripts/pre-rentree/verify_repository_hygiene.py --repo-root . && python scripts/pre-rentree/verify_release.py --artifact-root .artifacts/pre-rentree-2026/build --repo-root .",
    "pre-rentree:ci": "npm run pre-rentree:clean && npm run pre-rentree:snapshot && npm run pre-rentree:test:ts && npm run pre-rentree:test:py && npm run typecheck && npm run security:repo && npm run pre-rentree:build && npm run pre-rentree:audit && npm run pre-rentree:package && npm run pre-rentree:verify",
    "dev": "next dev",
    "build": "next build && node scripts/copy-public-assets.js && node scripts/release/verify-standalone-artifact.mjs",
    "build:base": "next build",
    "build:unsafe-local-only": "next build",
    "build:gate": "next build 2>&1 | tee build-output.log && node scripts/copy-public-assets.js && node scripts/release/verify-standalone-artifact.mjs && bash scripts/check-bundle-weight.sh build-output.log",
    "release:build": "next build && node scripts/copy-public-assets.js && node scripts/release/verify-standalone-artifact.mjs",
    "start": "next start",
    "start:prod": "node .next/standalone/server.js",
    "lint": "next lint --max-warnings 300",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.unit.config.js",
    "test:all": "npm test && npm run test:integration",
    "test:unit": "jest --config jest.unit.config.js",
    "test:unit:core": "jest --config jest.unit.config.js --testPathPattern='__tests__/lib/(core|generators)' --verbose",
    "test:unit:watch": "jest --config jest.unit.config.js --watch",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "test:db-integration": "npm run test:integration",
    "test:integration:with-db": "bash -lc \"if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then docker compose -f docker-compose.test.yml up -d; else echo 'Docker not available, skipping test DB startup'; fi\" && npm run test:integration",
    "test:integration:watch": "jest --config jest.integration.config.js --watch",
    "test:db": "npx jest --config jest.config.db.js --runInBand",
    "test:db:setup": "docker compose -f docker-compose.test.yml up -d && sleep 3 && npx prisma migrate deploy",
    "test:db:teardown": "docker compose -f docker-compose.test.yml down -v",
    "test:db:full": "npm run test:db:setup && npm run test:db && npm run test:db:teardown",
    "test:watch": "jest --projects jest.config.unit.js jest.config.integration.js --watch",
    "test:coverage": "jest --projects jest.config.unit.js jest.config.integration.js --coverage --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:smoke": "playwright test --config playwright.config.e2e.ts --grep 'Nexus 2.0|Bilan Gratuit|Admin Dashboard|LLM Resilience'",
    "check:e2e-syntax": "esbuild $(find e2e/ __tests__/e2e/ -name '*.spec.ts' -o -name '*.spec.tsx' 2>/dev/null) --bundle=false --outdir=/tmp/_chk --log-level=error",
    "check:no-hardcoded": "bash scripts/check-no-hardcoded.sh",
    "check:bundle-weight": "bash scripts/check-bundle-weight.sh build-output.log",
    "check:docs-archive": "node scripts/docs/check-archive-placement.js",
    "test:e2e:ephemeral": "npm run check:e2e-syntax && docker compose -f docker-compose.e2e.yml up --build --abort-on-container-exit --exit-code-from playwright && docker compose -f docker-compose.e2e.yml down -v",
    "test:e2e:ephemeral:down": "docker compose -f docker-compose.e2e.yml down -v",
    "test:e2e:setup": "bash scripts/setup-e2e-db.sh",
    "test:e2e:seed:parent": "tsx scripts/seed-parent-dashboard-e2e.ts",
    "test:e2e:teardown": "bash scripts/teardown-e2e-db.sh",
    "audit:contrast": "node scripts/audit-contrast.mjs",
    "audit:site-map": "node scripts/audit/site-map.mjs",
    "test:e2e:full": "bash -lc \"node -e \\\"const { chromium } = require('playwright'); chromium.launch({ headless: true, args: ['--no-sandbox'] }).then(b => b.close()).catch(() => process.exit(1));\\\"; if [ $? -ne 0 ]; then export SKIP_CHROMIUM=1; fi; npm run test:e2e:setup && SKIP_CHROMIUM=\\${SKIP_CHROMIUM} npm run test:e2e && npm run test:e2e:teardown\"",
    "test:ci": "npm test -- --coverage --maxWorkers=2 && npm run test:db-integration",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run test:db:full && npm run build",
    "verify:quick": "npm run lint && npm run typecheck && npm run test:unit && npm run test:integration",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "check-config": "node scripts/check-config.js",
    "security:telegram": "node scripts/security/check-telegram-secrets.mjs .",
    "security:repo": "bash scripts/security/check-no-private-keys.sh && npm run security:telegram",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:prod:local:up": "bash scripts/start-prod-local.sh",
    "docker:prod:local:down": "docker compose -f docker-compose.prod.yml -f docker-compose.prod.override.yml down",
    "docker:prod:domain:up": "bash scripts/start-prod-local-domain.sh",
    "docker:prod:domain:down": "docker compose -f docker-compose.prod.yml -f docker-compose.prod.override.yml -f docker-compose.prod.local-domain.override.yml down"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",

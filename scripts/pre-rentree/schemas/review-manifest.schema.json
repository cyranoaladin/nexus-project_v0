{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexusreussite.academy/schemas/pre-rentree-2026-review-manifest.schema.json",
  "title": "Pré-rentrée 2026 review manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "campaignId",
    "documentVersion",
    "repoSha",
    "snapshotSha256",
    "generatorSha256",
    "governanceModuleSha256",
    "governanceCliSha256",
    "approvalSchemaSha256",
    "publicStatus",
    "privateStatus",
    "contractualDossierPublicationBlocked",
    "artifactCount",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "campaignId": { "type": "string", "minLength": 1 },
    "documentVersion": { "type": "string", "minLength": 1 },
    "repoSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "snapshotSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "generatorSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "governanceModuleSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "governanceCliSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "approvalSchemaSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "publicStatus": { "type": "string", "minLength": 1 },
    "privateStatus": { "type": "string", "minLength": 1 },
    "contractualDossierPublicationBlocked": { "const": true },
    "artifactCount": { "type": "integer", "minimum": 1 },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role", "sha256", "fileSize"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "fileSize": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}

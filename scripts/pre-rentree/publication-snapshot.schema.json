{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexusreussite.academy/schemas/pre-rentree-2026-publication.snapshot.schema.json",
  "title": "Nexus Réussite Pré-rentrée 2026 publication snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sourceRepoSha",
    "generatedAt",
    "provenance",
    "campaign",
    "levels",
    "subjects",
    "blocks",
    "schedule",
    "academicProfiles",
    "packs",
    "modules",
    "content",
    "labels",
    "cta",
    "contact",
    "legal",
    "approvedPublicClaims",
    "assets",
    "document"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "sourceRepoSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "provenance": { "type": "object" },
    "campaign": { "type": "object" },
    "levels": { "type": "array", "minItems": 3, "maxItems": 3 },
    "subjects": { "type": "array", "minItems": 4, "maxItems": 4 },
    "blocks": { "type": "array", "minItems": 4, "maxItems": 4 },
    "schedule": {
      "type": "object",
      "required": ["weeks", "sessions"],
      "properties": {
        "weeks": { "type": "array", "minItems": 2, "maxItems": 2 },
        "sessions": { "type": "array", "minItems": 60, "maxItems": 60 }
      }
    },
    "academicProfiles": { "type": "object" },
    "packs": { "type": "array", "minItems": 4, "maxItems": 4 },
    "modules": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["id", "level", "subjectId", "title", "subtitle", "prerequisites", "differentiation", "quickAssessment", "sessions"],
        "properties": {
          "sessions": { "type": "array", "minItems": 5, "maxItems": 5 }
        }
      }
    },
    "content": { "type": "object" },
    "labels": { "type": "object" },
    "cta": { "type": "object" },
    "contact": { "type": "object" },
    "legal": { "type": "object" },
    "approvedPublicClaims": { "type": "array", "minItems": 1 },
    "assets": { "type": "object" },
    "document": { "type": "object" }
  }
}
